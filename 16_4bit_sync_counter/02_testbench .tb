module tb;
  
  reg clk;
  reg reset;
  wire [3:0] q;
  
  sync_counter_4bit uut(
    
    .clk(clk),
    .reset(reset),
    .q(q)
    
  );
  
  always #5 clk = ~clk;
  initial begin
    $dumpfile("sync_counter_4bit.vcd");
    $dumpvars(0,tb);
    $monitor(" time=%0t, clk=%b, reset=%b, q=%b",
             $time, clk, reset,q);
    
  end
  initial begin
    
    clk = 0;
    reset = 1;
    #10;
    
    reset = 0;
    clk = 0;
    #170;
    
    $finish;
    
  end
endmodule