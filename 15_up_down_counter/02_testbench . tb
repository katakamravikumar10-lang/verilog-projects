module tb;
  reg clk;
  reg reset;
  reg up_down;
  wire [3:0] q;
  
  up_down_counter uut(
    
    .clk(clk),
    .reset(reset),
    .up_down(up_down),
    .q(q)
    
  );
  
  always #5 clk = ~clk;
  
  initial begin 
    $dumpfile("up_down_counter.vcd");
    $dumpvars(0,tb);
    $monitor(" time=%0t, clk=%b, reset=%b, up_down=%b, q=%b",
             $time, clk, reset, up_down, q);
  end
  
  initial begin
    
    reset = 1;
    clk = 0;
    up_down = 0;
    #10;
    
    reset = 0;
    up_down = 1;
    #170;
    
    reset = 0;
    up_down = 0;
    #170;
    
    $finish;
  end
endmodule