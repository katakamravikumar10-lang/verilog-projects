module up_down_counter(
  
  input clk,
  input reset,
  input up_down,
  output reg [3:0] q
  
);
  always@(posedge clk or posedge reset)
    begin
    
    if (reset)
      q <= 4'b0000;
  else
    begin
      if(up_down)
        q <= q + 1;
      else
        q <= q - 1;
    end
    end
endmodule